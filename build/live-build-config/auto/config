#!/usr/bin/env bash
# =============================================================================
# DevForge OS — live-build auto/config
#
# Questo script configura live-build con tutti i parametri per
# costruire l'ISO di DevForge OS. Viene chiamato da 'lb config'.
#
# Documentazione live-build: https://live-team.pages.debian.net/live-manual/
# =============================================================================

set -euo pipefail

lb config \
    --distribution "bookworm" \
    --architectures "amd64" \
    --binary-images "iso-hybrid" \
    --debian-installer "live" \
    --debian-installer-gui "false" \
    --bootappend-live "boot=live components quiet splash locales=it_IT.UTF-8 keyboard-layouts=it" \
    --linux-flavours "amd64" \
    --memtest "none" \
    --iso-application "DevForge OS" \
    --iso-publisher "DevForge Project <https://github.com/devforge-os/devforge-os>" \
    --iso-volume "DevForgeOS" \
    --compression "xz" \
    --debootstrap-options "--include=apt-transport-https,ca-certificates,gnupg" \
    --archive-areas "main contrib non-free non-free-firmware" \
    --apt-recommends "false" \
    --apt-indices "none" \
    --cache "true" \
    --cache-packages "true" \
    "${@}"
